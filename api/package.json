{
  "name": "stabs-platform-api",
  "version": "2.0.0-dev",
  "description": "ID Document OCR API with Express.js",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "migrate": "node migrations/migrate.js",
    "lint": "eslint .",
    "format": "prettier --write '**/*.js'",
