# Environment variables template
# Copy to .env and fill with actual values

# Database
DATABASE_URL=postgresql://stabs_user:StabsSecure2026!@localhost:5432/stabs_ocr
DB_PASSWORD=StabsSecure2026!

# Encryption & Security
ENCRYPTION_KEY=your-encryption-key-here-32-characters-min
JWT_SECRET=your-jwt-secret-here-32-characters-min
API_KEY=your-api-key-here

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# OCR Service
OCR_SERVICE_URL=http://localhost:5000
OCR_TIMEOUT=30000

# Redis Cache
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:5173

# DRK Server Integration (Phase 2)
DRK_SERVER_API_KEY=your-drk-api-key
DRK_SERVER_URL=https://www.drkserver.org/api

# DeepSeek API (for NER)
DEEPSEEK_API_KEY=sk-a61cf0a19c5340faab78b9affc3c8d43

# Email/Notifications (Phase 2)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# AWS S3 for backups (Phase 2)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=stabs-backups

# Sentry for error tracking (Phase 2)
SENTRY_DSN=https://your-sentry-dsn
